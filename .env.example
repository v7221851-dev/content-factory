# Скопируйте: cp content-factory/.env.example content-factory/.env

# embedded = панель без API (Streamlit Cloud); api = отдельный сервер :8090
CONTENT_FACTORY_MODE=embedded

# Ключ для защиты API (заголовок X-API-Key)
CONTENT_FACTORY_API_KEY=change-me

# База: sqlite по умолчанию, для prod — postgresql+asyncpg://...
DATABASE_URL=sqlite+aiosqlite:///./content_factory.db

# --- VK ---
# ID группы без минуса, например 123456789
VK_GROUP_ID=
# Ключ сообщества — публикация текста на стену (Настройки группы → Работа с API → wall)
VK_ACCESS_TOKEN=
# Ключ пользователя-админа — загрузка фото (photos.getWallUploadServer недоступен с ключом сообщества!)
# Получить: vk.com/editapp → приложение → OAuth, scope: photos,wall,groups,offline
# https://oauth.vk.com/authorize?client_id=ВАШ_APP_ID&display=page&redirect_uri=https://oauth.vk.com/blank.html&scope=photos,wall,groups,offline&response_type=token&v=5.199
VK_USER_ACCESS_TOKEN=

# --- Telegram ---
# 1) @BotFather → /newbot → токен (не коммитьте!)
TELEGRAM_BOT_TOKEN=
# 2) Публичный канал: @username из ссылки t.me/username (рекомендуется)
#    Приватный: -100xxxxxxxxxx
# 3) Бот — админ канала, право «Публикация сообщений»
#    Проверка: PYTHONPATH=. python3 scripts/telegram_check.py
TELEGRAM_CHANNEL_ID=

# Ссылка на приложение / сайт в CTA
MDSA_APP_URL=https://mdsa.tech

# RSS: интервал авто-сбора в минутах (0 = только вручную)
RSS_FETCH_INTERVAL_MINUTES=0

# Очередь согласования и автопубликация
DAILY_REVIEW_LIMIT=5
DEFAULT_PUBLISH_PLATFORMS=vk,telegram
DAILY_PREPARE_ENABLED=true
DAILY_PREPARE_HOUR=8
DAILY_PREPARE_MINUTE=0

# Интервал между публикациями (минуты). 5 статей ≈ 2.5 часа при 30 мин.
PUBLISH_INTERVAL_MINUTES=30

# Длина превью статьи в посте VK (~12–15 строк, по умолчанию 1800 символов)
POST_PREVIEW_MAX_CHARS=1800
